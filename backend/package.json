{
  "name": "declutter-me",
  "version": "1.0.0",
  "description": "Smart & customizable organizer",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "debug": "nodemon app.js",
    "test": "mocha --recursive",
    "test:watch": "npm run test -- --watch",
    "test:mutate": "stryker run",
    "test:integration": "mocha --recursive integration-test",
    "test:integration:watch": "npm run test:integration -- --watch",
    "test:all": "npm run test && npm run test:integration"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitaly-rudenko/declutter-me.git"
  },
  "keywords": [
    "organizer",
    "notes",
    "telegram-bot",
    "notion"
  ],
  "author": "Vitaly Rudenko",
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://github.com/vitaly-rudenko/declutter-me/issues"
  },
  "homepage": "https://github.com/vitaly-rudenko/declutter-me#readme",
  "dependencies": {
    "@notionhq/client": "^0.1.9",
    "base64url": "^3.0.1",
    "better-sqlite3": "^7.4.0",
    "dotenv": "^10.0.0",
    "log4js": "^6.3.0",
    "markdown-escapes": "^2.0.0",
    "pako": "^2.0.3",
    "telegraf": "^4.3.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^5.0.1",
    "@stryker-mutator/mocha-runner": "^5.0.1",
    "chai": "^4.3.4",
    "chai-as-promised": "^7.1.1",
    "common-tags": "^1.8.0",
    "deep-equal-in-any-order": "^1.0.28",
    "mocha": "^8.3.2",
    "nodemon": "^2.0.7",
    "sinon": "^9.2.4",
    "sinon-chai": "^3.5.0"
  }
}
